    </Target>
    <Target Name="Clean">
        <CallTarget Targets="TeamoworkFriendlyDproj:Clean;DprojSanitizerTest:Clean;DprojSanitizerCli:Clean"/>
    </Target>
    <Target Name="Make">
        <CallTarget Targets="TeamoworkFriendlyDproj:Make;DprojSanitizerTest:Make;DprojSanitizerCli:Make"/>
    </Target>
    <Import Project="$(BDS)\Bin\CodeGear.Group.Targets" Condition="Exists('$(BDS)\Bin\CodeGear.Group.Targets')"/>
